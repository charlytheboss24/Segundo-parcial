numeros = []

for i in range(5):
    num = float(input("Ingresa un número: "))
    numeros.append(num)

mayor = max(numeros)
menor = min(numeros)
promedio = sum(numeros) / len(numeros)

print("El número mayor es:", mayor)
print("El número menor es:", menor)
print("El promedio de los números es:", promedio)
